# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# local sqlite/runtime files
prisma/*.db
prisma/*.db-shm
prisma/*.db-wal

# user uploaded runtime assets
public/uploads/**
!public/uploads/
!public/uploads/.gitkeep
!public/uploads/avatars/
!public/uploads/avatars/.gitkeep
!public/uploads/competitions/
!public/uploads/competitions/.gitkeep
!public/uploads/documents/
!public/uploads/documents/.gitkeep

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
